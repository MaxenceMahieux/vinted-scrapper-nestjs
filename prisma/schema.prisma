generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Une recherche sauvegardée : l'ensemble des filtres qu'on rejoue à chaque cycle.
model SavedSearch {
  id              String   @id @default(cuid())
  name            String
  enabled         Boolean  @default(true)

  searchText      String?
  catalogIds      Int[]    @default([])
  brandIds        Int[]    @default([])
  statusIds       Int[]    @default([]) // Vinted condition ids (etat)
  sizeIds         Int[]    @default([])
  priceFrom       Decimal? @db.Decimal(10, 2)
  priceTo         Decimal? @db.Decimal(10, 2)
  order           String   @default("newest_first")
  country         String   @default("fr") // domaine vinted: fr/de/it/es/be...
  includeKeywords String[] @default([])
  excludeKeywords String[] @default([])
  channels        String[] @default(["telegram"]) // cles de canaux de notif actives
  dealOnly        Boolean  @default(false)
  minDealScore    Float? // seuil 0..1 si dealOnly

  lastRunAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  listings        Listing[]
  observations    PriceObservation[]

  @@index([enabled])
}

/// Une annonce vue. Dédupliquée par (recherche, item Vinted) pour ne notifier qu'une fois.
model Listing {
  id           String      @id @default(cuid())
  vintedItemId BigInt
  search       SavedSearch @relation(fields: [searchId], references: [id], onDelete: Cascade)
  searchId     String

  title        String
  price        Decimal     @db.Decimal(10, 2)
  totalPrice   Decimal?    @db.Decimal(10, 2) // prix effectif acheteur (article + protection)
  currency     String      @default("EUR")
  url          String
  photoUrl     String?
  brand        String?
  size         String?
  condition    String? // libelle d'etat Vinted (ex. "Tres bon etat")
  statusId     Int? // id d'etat Vinted (pour segmenter le pricing)
  sellerLogin  String?
  publishedAt  DateTime?

  modelKey     String? // cle de modele normalisee (pricing)
  dealScore    Float?
  isDeal       Boolean     @default(false)
  isFavorite   Boolean     @default(false) // marque "favori" depuis Telegram

  notified     Boolean     @default(false)
  seenAt       DateTime    @default(now())

  @@unique([searchId, vintedItemId])
  @@index([notified])
  @@index([modelKey])
}

/// Un relevé de prix pour un modèle donné, alimentant les statistiques de pricing.
model PriceObservation {
  id           String       @id @default(cuid())
  vintedItemId BigInt
  modelKey     String
  statusId     Int          @default(0) // etat Vinted (0 = inconnu) pour stats par condition
  price        Decimal      @db.Decimal(10, 2)
  currency     String       @default("EUR")
  search       SavedSearch? @relation(fields: [searchId], references: [id], onDelete: SetNull)
  searchId     String?
  observedAt   DateTime     @default(now())

  @@index([modelKey])
  @@index([observedAt])
}

/// Statistiques de prix agrégées par modèle ET par état (recalculées périodiquement).
/// La ligne statusId = 0 est l'agrégat tous états confondus (repli quand une
/// condition précise manque d'échantillons).
model PriceStat {
  modelKey  String
  statusId  Int      @default(0)
  median    Decimal  @db.Decimal(10, 2)
  p25       Decimal  @db.Decimal(10, 2)
  samples   Int
  updatedAt DateTime @updatedAt

  @@id([modelKey, statusId])
}

/// Un article suivi individuellement pour être alerté en cas de baisse de prix.
model TrackedItem {
  id            String   @id @default(cuid())
  vintedItemId  BigInt   @unique
  chatId        String // chat Telegram qui suit l'article
  title         String
  url           String
  photoUrl      String?
  currency      String   @default("EUR")
  country       String   @default("fr")
  initialPrice  Decimal  @db.Decimal(10, 2)
  lastPrice     Decimal  @db.Decimal(10, 2)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  lastCheckedAt DateTime?

  @@index([active])
}

/// Un vendeur dont les annonces ne doivent plus déclencher de notification.
model MutedSeller {
  sellerLogin String   @id
  createdAt   DateTime @default(now())
}
