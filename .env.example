# App
PORT=3000

# Base de données (en local hors Docker, sinon surchargé par docker-compose)
DATABASE_URL=postgresql://vinted:vinted@localhost:5432/vinted?schema=public

# Redis (queue BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Vinted
VINTED_BASE_URL=https://www.vinted.fr
# Intervalle du cron de scraping (expression cron). Défaut : toutes les 60s.
SCRAPE_CRON=*/60 * * * * *

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
